#include <iostream>
using namespace std;

void processMetric(string metric) {
    cout << "Processing: " << metric << endl;

    if (metric == "Revenue") {
        cout << "Displaying Revenue Growth Chart..." << endl;
    } else if (metric == "Net Income") {
        cout << "Showing Net Income Performance Graph..." << endl;
    } else if (metric == "EPS") {
        cout << "Visualizing Earnings Per Share (EPS) Trend..." << endl;
    } else {
        cout << "Displaying Generic Metric Trend Graph..." << endl;
    }
}

int main() {
    string metrics[] = {"Revenue", "Net Income", "EPS"};

    for (int i = 0; i < 3; i++) {
        processMetric(metrics[i]); // Calling the function
    }

    return 0;
}
